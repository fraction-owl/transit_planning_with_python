{
  "_comment": [
    "Registry for prep_features_public.py wired to the route_ols_run_1 extracted layout.",
    "{input} is the input-data root (...\\input\\data); topic subfolders are referenced",
    "directly (gtfs_input/connector_gtfs_2026_04_29, poi_inputs, schools_input,",
    "census_input/tables, census_input/shps, cabi_input). Run with:",
    "  python prep_features_public.py --registry <this file> --input-dir ...\\input\\data --output-dir ...\\prepped_features",
    "Caveats: (1) install scipy/geopandas/shapely first; (2) gbfs scripts omitted (no GBFS",
    "source + multi-stage deps); (3) verify each script's real output filenames + keep_cols",
    "against work\\out\\<script>\\ and adjust the outputs block if they differ."
  ],
  "scripts": [
    {
      "script": "gtfs_route_features.py",
      "cmd": ["{python}", "{script}",
              "--gtfs-dir", "{input}/gtfs_input/connector_gtfs_2026_04_29",
              "--output-dir", "{output}"],
      "outputs": [
        {"file": "gtfs_route_features.csv", "join_keys": ["route_id"],
         "keep_cols": ["trips_per_day", "span_hours", "median_headway_min", "pct_day_with_service",
                       "route_length_mi", "route_length_modal_mi", "avg_speed_mph", "n_stops",
                       "stops_per_mile", "shared_stop_share", "n_competitor_routes",
                       "competitor_trips_at_shared_stops", "competition_intensity"]}
      ]
    },
    {
      "script": "headway_span_exporter.py",
      "cmd": ["{python}", "{script}",
              "--gtfs-folder", "{input}/gtfs_input/connector_gtfs_2026_04_29",
              "--output", "{output}/headway_span_by_route.csv"],
      "outputs": [
        {"file": "headway_span_by_route.csv", "join_keys": ["route_id"],
         "keep_cols": ["avg_headway_min", "span_hrs"]}
      ]
    },
    {
      "script": "route_transfer_calculator.py",
      "cmd": ["{python}", "{script}",
              "--gtfs-dirs", "{input}/gtfs_input/connector_gtfs_2026_04_29",
              "--output-dir", "{output}"],
      "outputs": [
        {"file": "route_transfers_summary.csv", "join_keys": ["route_id"],
         "keep_cols": ["transfer_route_count"]}
      ]
    },
    {
      "script": "points_of_interest_coverage_gpd.py",
      "cmd": ["{python}", "{script}",
              "--gtfs-dir", "{input}/gtfs_input/connector_gtfs_2026_04_29",
              "--shp-input-dir", "{input}/poi_inputs",
              "--output-dir", "{output}"]
    },
    {
      "script": "schools_prep_join_gpd.py",
      "cmd": ["{python}", "{script}",
              "--input-dir", "{input}/schools_input",
              "--output-dir", "{output}",
              "--school-type", "all"]
    },
    {
      "script": "school_coverage_by_route_gpd.py",
      "cmd": ["{python}", "{script}",
              "--gtfs-dir", "{input}/gtfs_input/connector_gtfs_2026_04_29",
              "--schools-path", "{work}/out/schools_prep_join_gpd",
              "--output-dir", "{output}"]
    },
    {
      "script": "bikeshare_ridership_trends.py",
      "cmd": ["{python}", "{script}",
              "--input", "{input}/cabi_input",
              "--output-dir", "{output}"]
    },
    {
      "script": "uscensus_tiger_join_gpd.py",
      "cmd": ["{python}", "{script}",
              "--input-csv-dir", "{input}/census_input/tables",
              "--input-shp-dir", "{input}/census_input/shps",
              "--output", "{output}/census_tiger_join.shp"]
    },
    {
      "script": "gtfs_service_demographics_gpd.py",
      "cmd": ["{python}", "{script}",
              "--gtfs-path", "{input}/gtfs_input/connector_gtfs_2026_04_29",
              "--demographics-shp", "{work}/out/uscensus_tiger_join_gpd/census_tiger_join.shp",
              "--output-dir", "{output}",
              "--analysis-mode", "route",
              "--service-area-method", "stop_buffer"]
    }
  ],
  "outputs": [
    {"file": "headway_span_by_route.csv", "join_keys": ["route_id"],
     "keep_cols": ["avg_headway_min", "span_hrs"]},
    {"file": "school_coverage_by_route.csv", "join_keys": ["route_id"],
     "keep_cols": ["schools_served", "enrollment_served", "enrollment_1_8_served",
                   "enrollment_9_12_served", "enrollment_postsec_served"]}
  ]
}
